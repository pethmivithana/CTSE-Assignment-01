# =============================================================================
# Feedo Microservices - Environment Variables
# =============================================================================
# This is an EXAMPLE file showing required environment variables.
# For local development, copy this to .env and fill in your actual values.
# NEVER commit actual .env files with real secrets to version control.
# =============================================================================

# =============================================================================
# API GATEWAY
# =============================================================================
PORT=3001
JWT_SECRET=your_jwt_secret_here_min_32_chars
INTERNAL_API_KEY=your_internal_api_key_min_32_chars

# =============================================================================
# MICROSERVICE URLS (for local Docker Compose)
# When deployed to Azure, these should point to Container Apps:
# http://feedo-user-service (internal DNS name)
# =============================================================================
USER_SERVICE_URL=http://user-service:3001
RESTAURANT_SERVICE_URL=http://restaurant-service:3002
ORDER_SERVICE_URL=http://order-service:3004
DELIVERY_SERVICE_URL=http://delivery-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3005
PAYMENT_SERVICE_URL=http://payment-service:3006

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For local Docker Compose: mongodb://mongodb:27017/admin
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/admin?retryWrites=true&w=majority
# For Azure Cosmos DB: mongodb+srv://user:password@cosmos.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000
MONGO_URI=mongodb://mongodb:27017/admin
MONGODB_URI=mongodb://mongodb:27017/admin

# =============================================================================
# EMAIL / SMTP CONFIGURATION
# For Gmail: Use App-Specific Password (not your Gmail password)
# Create at: https://myaccount.google.com/apppasswords
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=your_email@gmail.com

# =============================================================================
# APPLICATION URLS
# =============================================================================
# For local development: http://localhost:3000 and http://localhost:3001
# For Azure: https://feedo-frontend-XXXX.azurecontainerapps.io and https://feedo-api-gateway-XXXX.azurecontainerapps.io
APP_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:3001

# =============================================================================
# PAYMENT GATEWAY (STRIPE)
# Get keys from: https://dashboard.stripe.com/apikeys
# Use TEST keys during development
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=development
# Production: NODE_ENV=production

# =============================================================================
# OPTIONAL: MONITORING & LOGGING
# =============================================================================
# For Azure Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=your_insights_key_here

# For CloudWatch (AWS)
AWS_REGION=us-east-1

# =============================================================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# =============================================================================
# Add any other service API keys needed:
# - Google Maps API Key (for delivery tracking)
# - PayPal credentials (if using PayPal)
# - SendGrid API Key (if using SendGrid instead of SMTP)
# - Twilio credentials (for SMS notifications)

# =============================================================================
# NOTES FOR DEPLOYMENT
# =============================================================================
# 1. LOCAL DEVELOPMENT:
#    - Copy this file to .env
#    - Fill in values for local services
#    - Run: docker compose up -d
#
# 2. GITHUB ACTIONS CI/CD:
#    - Add secrets in GitHub: Settings → Secrets and variables → Actions
#    - SONAR_TOKEN (from sonarcloud.io)
#    - SNYK_TOKEN (from snyk.io) [optional]
#
# 3. AZURE CONTAINER APPS:
#    - Store secrets in Azure Key Vault
#    - Reference them in container app env vars
#    - Example: @Microsoft.KeyVault(SecretUri=https://vault-name.vault.azure.net/secrets/secret-name/)
#    - Never pass secrets directly to container apps
#
# 4. SECURITY BEST PRACTICES:
#    - Never commit .env files with real values
#    - Rotate secrets regularly
#    - Use strong random values (openssl rand -base64 32)
#    - Different secrets for dev, staging, production
#    - Monitor secret usage in logs
# =============================================================================
