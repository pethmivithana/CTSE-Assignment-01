PORT=3005


MONGODB_URI=mongodb://localhost:27017/notification_db
JWT_SECRET=your_jwt_secret_here

# Optional: require on internal routes (order/delivery/payment services must send this header)
INTERNAL_API_KEY=a8f3c2d91b6e4a7f8c9e1234567890abcdef1234567890abcdef1234567890ab

# Email (optional — without SMTP, emails are logged only)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@feedo.com

# Links in emails
APP_URL=http://localhost:3000

# Other services (resolve restaurant manager, user email)
USER_SERVICE_URL=http://localhost:5002
RESTAURANT_SERVICE_URL=http://localhost:3002

# Push — optional JSON string of Firebase service account
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Future: RabbitMQ / Kafka (not required — in-process queue + retries are built-in)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672

