# Copy to `.env` (never commit `.env` — it is gitignored)
PORT=3006
MONGO_URI=mongodb://localhost:27017/payment_db

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_with_your_secret_key
STRIPE_WEBHOOK_SECRET=

# PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

PUBLIC_APP_URL=http://localhost:3000
ORDER_SERVICE_URL=http://localhost:3004

PAYMENT_DUPLICATE_WINDOW_MS=300000
PAYMENT_HIGH_AMOUNT_LKR=50000
PAYMENT_RISK_BLOCK_THRESHOLD=95
FAIL_PAYMENTS=false
ENABLE_WALLET_TOPUP=false
