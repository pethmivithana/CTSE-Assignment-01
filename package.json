{
  "name": "feedo",
  "version": "1.0.0",
  "description": "Microservice-based ecommerce application",
  "scripts": {
    "dev": "node dev.js",
    "dev:logs": "docker compose logs -f",
    "dev:down": "docker compose down",
    "dev:mongo": "docker compose -f docker-compose.mongo.yml up -d",
    "dev:mongo:down": "docker compose -f docker-compose.mongo.yml down",
    "health-check": "node scripts/health-check.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "helmet": "^8.1.0",
    "http-proxy": "^1.18.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "socket.io": "^4.8.3"
  }
}
