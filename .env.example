# Copy to `.env` in the project root for docker-compose (optional — compose has defaults)
JWT_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb://localhost:27017/feedo
INTERNAL_API_KEY=a8f3c2d91b6e4a7f8c9e1234567890abcdef1234567890abcdef1234567890ab
APP_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:3001

# Email (user-service + notification-service) — optional; leave host empty to log only
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@feedo.com

# Payments — use keys from https://dashboard.stripe.com/test/apikeys (never commit real keys)
STRIPE_SECRET_KEY=sk_test_replace_with_your_secret_key
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key
