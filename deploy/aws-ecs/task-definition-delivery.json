{
  "family": "feedo-delivery-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/feedo-task-role",
  "containerDefinitions": [
    {
      "name": "delivery-service",
      "image": "ghcr.io/YOUR_ORG/feedo-delivery-service:latest",
      "portMappings": [{ "containerPort": 3003 }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3003" }
      ],
      "secrets": [
        { "name": "MONGODB_URI", "valueFrom": "arn:aws:secretsmanager:region:ACCOUNT_ID:secret:feedo/mongodb" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:region:ACCOUNT_ID:secret:feedo/jwt" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/feedo-delivery",
          "awslogs-region": "us-east-1"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q -O- http://localhost:3003/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
